# Docker Compose 用の環境変数
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# JWT 署名キー（32文字以上推奨）
JWT_KEY=your-jwt-secret-key-at-least-32-characters

# フロントエンドの API 接続先（デフォルトのままで OK）
NEXT_PUBLIC_API_BASE_URL=http://localhost:5150
